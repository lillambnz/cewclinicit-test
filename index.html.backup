                <li><a href="#contact" class="nav-link">Contact</a></li>
            </ul>
            <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
                <i class="fas fa-sun"></i>
                <i class="fas fa-moon"></i>
            </button>
            <div class="nav-toggle">
                <i class="fas fa-bars"></i>
            </div>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>Transform Your GP Clinic with Cutting-Edge Technology Solutions</h1>
                    <p class="hero-subtitle">Designed to solve the most critical IT challenges faced by Western Australian healthcare practices. Eliminate data silos, upgrade outdated systems, and deliver a future-ready practice that's efficient, connected, and patient-centered.</p>
                    <div class="hero-stats">
                        <div class="stat">
                            <span class="stat-number">1</span>
                            <span class="stat-label">Trusted Clinic Partner</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">24/7</span>
                            <span class="stat-label">Support Available</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">100%</span>
                            <span class="stat-label">Australian Focused</span>
                        </div>
                    </div>
                    <div class="hero-buttons">
                        <a href="#contact" class="btn btn-primary">Get Your Free Consultation</a>
                        <a href="#services" class="btn btn-secondary">Explore Services</a>
                    </div>
                </div>
                <div class="hero-image">
                    <div class="transformation-matrix">
                        <!-- Digital DNA Helix representing practice transformation -->
                        <div class="dna-helix">
                            <div class="helix-strand strand-1"></div>
                            <div class="helix-strand strand-2"></div>
                            <div class="helix-connections"></div>
                        </div>
                        
                        <!-- Neural Network Nodes showing interconnected systems -->
                        <div class="neural-network">
                            <div class="neural-node node-center" data-system="core">
                                <div class="node-pulse"></div>
                                <span class="node-label">Practice Core</span>
                            </div>
                            <div class="neural-node node-1" data-system="ehr">
                                <div class="node-pulse"></div>
                                <span class="node-label">EHR</span>
                            </div>
                            <div class="neural-node node-2" data-system="billing">
                                <div class="node-pulse"></div>
                                <span class="node-label">Billing</span>
                            </div>
                            <div class="neural-node node-3" data-system="security">
                                <div class="node-pulse"></div>
                                <span class="node-label">Security</span>
                            </div>
                            <div class="neural-node node-4" data-system="ai">
                                <div class="node-pulse"></div>
                                <span class="node-label">AI Tools</span>
                            </div>
                            <div class="neural-node node-5" data-system="cloud">
                                <div class="node-pulse"></div>
                                <span class="node-label">Cloud</span>
                            </div>
                        </div>
                        
                        <!-- Data Flow Particles -->
                        <div class="data-streams">
                            <div class="data-particle particle-1"></div>
                            <div class="data-particle particle-2"></div>
                            <div class="data-particle particle-3"></div>
                            <div class="data-particle particle-4"></div>
                            <div class="data-particle particle-5"></div>
                            <div class="data-particle particle-6"></div>
                        </div>
                        
                        <!-- Holographic Progress Rings -->
                        <div class="progress-rings">
                            <div class="progress-ring ring-1">
                                <div class="ring-progress" data-progress="95"></div>
                                <div class="ring-label">System Integration</div>
                            </div>
                            <div class="progress-ring ring-2">
                                <div class="ring-progress" data-progress="100"></div>
                                <div class="ring-label">Security Level</div>
                            </div>
                            <div class="progress-ring ring-3">
                                <div class="ring-progress" data-progress="87"></div>
                                <div class="ring-label">Efficiency Gain</div>
                            </div>
                        </div>
                        
                        <!-- Quantum Effect Background -->
                        <div class="quantum-field">
                            <div class="quantum-particle q-1"></div>
                            <div class="quantum-particle q-2"></div>
                            <div class="quantum-particle q-3"></div>
                            <div class="quantum-particle q-4"></div>
                            <div class="quantum-particle q-5"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- AI Empire Control Center -->
    <section class="ai-empire-section">
        <div class="ai-empire-content">
            <div class="ai-empire-header">
                <h2 class="ai-empire-title">🤖 AI-Powered Clinical IT Empire</h2>
                <p class="ai-empire-subtitle">Australia's First AI-Native Healthcare Technology Platform</p>
                <p>Revolutionizing clinical IT consulting with advanced artificial intelligence, 24/7 automated support, and predictive insights that keep you ahead of the market.</p>
            </div>
            
            <div class="ai-stats-grid">
                <div class="ai-stat-card">
                    <span class="ai-stat-number">24/7</span>
                    <div class="ai-stat-label">AI Support Available</div>
                </div>
                <div class="ai-stat-card">
                    <span class="ai-stat-number">247+</span>
                    <div class="ai-stat-label">Articles Generated Monthly</div>
                </div>
                <div class="ai-stat-card">
                    <span class="ai-stat-number">7</span>
                    <div class="ai-stat-label">Advanced AI Tools</div>
                </div>
                <div class="ai-stat-card">
                    <span class="ai-stat-number">95%</span>
                    <div class="ai-stat-label">Problem Resolution Rate</div>
                </div>
            </div>
            
            <div class="ai-tools-showcase">
                <div class="ai-tool-showcase" onclick="openAITool('chat')">
                    <div class="ai-tool-icon">💬</div>
                    <h3 class="ai-tool-name">MedTech Clara AI</h3>
                    <p class="ai-tool-description">Intelligent chat assistant with deep clinical IT expertise. Get instant answers about integrations, compliance, and troubleshooting.</p>
                    <span class="ai-tool-status">Active Now</span>
                </div>
                
                <div class="ai-tool-showcase" onclick="openAITool('analyzer')">
                    <div class="ai-tool-icon">🏥</div>
                    <h3 class="ai-tool-name">AI Practice Analyzer</h3>
                    <p class="ai-tool-description">Comprehensive AI-powered assessment of your practice's IT infrastructure with personalized optimization recommendations.</p>
                    <span class="ai-tool-status">Free Analysis</span>
                </div>
                
                <div class="ai-tool-showcase" onclick="openAITool('matchmaker')">
                    <div class="ai-tool-icon">🔍</div>
                    <h3 class="ai-tool-name">Software Matchmaker</h3>
                    <p class="ai-tool-description">AI-powered software recommendation engine matching your practice needs with the perfect clinical IT solutions.</p>
                    <span class="ai-tool-status">Instant Matching</span>
                </div>
                
                <div class="ai-tool-showcase" onclick="openAITool('roi')">
                    <div class="ai-tool-icon">💰</div>
                    <h3 class="ai-tool-name">ROI Calculator</h3>
                    <p class="ai-tool-description">Advanced AI-driven ROI analysis for IT investments. See exactly how much you'll save and earn from technology improvements.</p>
                    <span class="ai-tool-status">Calculate Now</span>
                </div>
                
                <div class="ai-tool-showcase" onclick="openAITool('knowledge')">
                    <div class="ai-tool-icon">📚</div>
                    <h3 class="ai-tool-name">Smart Knowledge Base</h3>
                    <p class="ai-tool-description">AI-curated library of clinical IT information, updated in real-time with the latest compliance requirements and best practices.</p>
                    <span class="ai-tool-status">Always Updated</span>
                </div>
                
                <div class="ai-tool-showcase" onclick="openAITool('troubleshooter')">
                    <div class="ai-tool-icon">🔧</div>
                    <h3 class="ai-tool-name">AI Troubleshooter</h3>
                    <p class="ai-tool-description">Step-by-step AI-guided problem diagnosis and resolution. Fix common issues instantly with intelligent support.</p>
                    <span class="ai-tool-status">Instant Help</span>
                </div>
            </div>
            
            <div class="ai-cta-section">
                <h3 class="ai-cta-title">Experience the Future of Clinical IT Support</h3>
                <p>Join Australia's most advanced AI-powered healthcare technology platform. Get instant access to expert-level guidance that never sleeps.</p>
                
                <div class="ai-cta-buttons">
                    <button class="ai-cta-button" onclick="startAIExperience()">
                        🚀 Launch AI Assistant
                    </button>
                    <button class="ai-cta-button secondary" onclick="openAITool('analyzer')">
                        🏥 Free Practice Analysis
                    </button>
                    <button class="ai-cta-button secondary" onclick="bookAIConsultation()">
                        📞 Book AI-Assisted Consultation
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <div class="section-header">
                <h2>Solve Your Most Critical IT Challenges</h2>
                <p>Integrated solutions that eliminate inefficiencies, upgrade outdated systems, and deliver major health IT projects on time—no more delays or "false starts"</p>
            </div>
            <div class="services-grid">
                <a href="clinical-systems-integration.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-link"></i>
                        </div>
                        <h3>Clinical Systems Integration</h3>
                        <p>Seamlessly integrate all clinical systems to eliminate data silos and duplication. Connect Best Practice, Medical Director, Zedmed, and third-party tools into one unified workflow.</p>
                        <ul class="service-features">
                            <li>End-to-end system integration</li>
                            <li>Eliminate duplicate data entry</li>
                            <li>Real-time data synchronisation</li>
                            <li>Medicare & health fund connectivity</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>

                <a href="infrastructure-modernisation.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h3>Infrastructure Modernisation</h3>
                        <p>Upgrade outdated infrastructure and legacy software for reliable, secure operations. Transform aging systems into modern, efficient platforms that protect patient information.</p>
                        <ul class="service-features">
                            <li>Legacy system upgrades</li>
                            <li>Modern cybersecurity hardening</li>
                            <li>Privacy Act & healthcare compliance</li>
                            <li>Zero-downtime migrations</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>

                <a href="electronic-health-records.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-file-medical"></i>
                        </div>
                        <h3>Electronic Health Records</h3>
                        <p>Deploy user-friendly electronic health records with real-time access and sharing across providers. Bridge digital communication gaps between GPs, hospitals, and patients.</p>
                        <ul class="service-features">
                            <li>Real-time EHR access & sharing</li>
                            <li>Cross-provider connectivity</li>
                            <li>Patient portal integration</li>
                            <li>Secure inter-facility communication</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>

                <a href="automation-ai-tools.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-robot"></i>
                        </div>
                        <h3>Automation & AI Tools</h3>
                        <p>Implement automation tools to reduce manual data entry and administrative burden. Accelerate telehealth, remote monitoring, and AI-powered tools for smarter care.</p>
                        <ul class="service-features">
                            <li>Automated data entry & workflows</li>
                            <li>AI-powered diagnostic assistance</li>
                            <li>Telehealth & remote monitoring</li>
                            <li>Smart scheduling & reminders</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>

                <a href="team-training-support.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <h3>Team Training & Support</h3>
                        <p>Empower your team with tailored IT training and support. Attract and retain tech talent with smart recruitment solutions and ongoing professional development.</p>
                        <ul class="service-features">
                            <li>Tailored staff IT training</li>
                            <li>Tech talent recruitment support</li>
                            <li>24/7 technical helpdesk</li>
                            <li>Ongoing skill development programs</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>

                <a href="major-it-project-delivery.html" class="service-card-link">
                    <div class="service-card">
                        <div class="service-icon">
                            <i class="fas fa-project-diagram"></i>
                        </div>
                        <h3>Major IT Project Delivery</h3>
                        <p>Deliver major health IT projects on time, every time—no more delays or "false starts." Comprehensive project management from planning to successful implementation.</p>
                        <ul class="service-features">
                            <li>On-time project delivery guarantee</li>
                            <li>Comprehensive project management</li>
                            <li>Risk mitigation & contingency planning</li>
                            <li>Post-implementation support & optimization</li>
                        </ul>
                        <div class="service-learn-more">Learn More <i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <div class="about-content">
                <div class="about-text">
                    <h2>Why Choose ClinicIT.Solutions?</h2>
                    <p class="about-lead">Based in Perth, we specialise in solving the most critical IT challenges faced by Western Australian GP clinics. Our integrated solutions eliminate data silos, modernise outdated systems, and deliver major health IT projects without delays or false starts.</p>
                    
                    <div class="about-features">
                        <div class="feature">
                            <div class="feature-icon">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <div class="feature-content">
                                <h4>Western Australian Focus</h4>
                                <p>Deep understanding of WA healthcare regulations, Medicare integration requirements, and the specific IT challenges facing Perth and regional GP clinics.</p>
                            </div>
                        </div>

                        <div class="feature">
                            <div class="feature-icon">
