    <link rel="stylesheet" href="styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- AI Empire Styles -->
    <style>
        .ai-empire-section {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            padding: 80px 20px;
            position: relative;
            overflow: hidden;
        }
        
        .ai-empire-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="25" cy="25" r="2" fill="%2310a37f" opacity="0.3"><animate attributeName="opacity" values="0.3;1;0.3" dur="3s" repeatCount="indefinite"/></circle><circle cx="75" cy="25" r="1.5" fill="%2310a37f" opacity="0.5"><animate attributeName="opacity" values="0.5;1;0.5" dur="4s" repeatCount="indefinite"/></circle><circle cx="50" cy="75" r="1" fill="%2310a37f" opacity="0.4"><animate attributeName="opacity" values="0.4;1;0.4" dur="2s" repeatCount="indefinite"/></circle></svg>');
            pointer-events: none;
        }
        
        .ai-empire-content {
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }
        
        .ai-empire-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        .ai-empire-title {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #10a37f, #22d3ee);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .ai-empire-subtitle {
            font-size: 1.5rem;
            opacity: 0.9;
            margin-bottom: 30px;
        }
        
        .ai-stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        
        .ai-stat-card {
            background: rgba(16, 163, 127, 0.1);
            border: 2px solid rgba(16, 163, 127, 0.3);
            border-radius: 15px;
            padding: 30px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .ai-stat-card:hover {
            transform: translateY(-5px);
            border-color: rgba(16, 163, 127, 0.6);
            box-shadow: 0 10px 30px rgba(16, 163, 127, 0.2);
        }
        
        .ai-stat-number {
            font-size: 3rem;
            font-weight: 700;
            color: #10a37f;
            margin-bottom: 10px;
            display: block;
        }
        
        .ai-stat-label {
            font-size: 1.1rem;
            font-weight: 600;
            opacity: 0.9;
        }
        
        .ai-tools-showcase {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        
        .ai-tool-showcase {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .ai-tool-showcase:hover {
            transform: translateY(-3px);
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(16, 163, 127, 0.5);
        }
        
        .ai-tool-icon {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: #10a37f;
        }
        
        .ai-tool-name {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 15px;
        }
        
        .ai-tool-description {
            opacity: 0.8;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .ai-tool-status {
            display: inline-block;
            background: linear-gradient(135deg, #10a37f, #059669);
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .ai-cta-section {
            text-align: center;
            background: linear-gradient(135deg, #10a37f, #059669);
            padding: 40px;
            border-radius: 20px;
            margin-top: 40px;
        }
        
        .ai-cta-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .ai-cta-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 30px;
        }
        
        .ai-cta-button {
            background: white;
            color: #10a37f;
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
        }
        
        .ai-cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 255, 255, 0.3);
            background: #f8fafc;
        }
        
        .ai-cta-button.secondary {
            background: transparent;
            color: white;
            border: 2px solid white;
        }
        
        .ai-cta-button.secondary:hover {
            background: white;
            color: #10a37f;
        }
        
        @media (max-width: 768px) {
            .ai-empire-title {
                font-size: 2.5rem;
            }
            
            .ai-empire-subtitle {
                font-size: 1.2rem;
            }
            
            .ai-stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
            
            .ai-tools-showcase {
                grid-template-columns: 1fr;
            }
            
            .ai-cta-buttons {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-81P3CZ3QFX"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        
        gtag('config', 'G-81P3CZ3QFX', {
            'anonymize_ip': true,
            'cookie_flags': 'secure;samesite=strict'
        });
    </script>
</head>
<body>
    <!-- Header -->
    <header class="header">
